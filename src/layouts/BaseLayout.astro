---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Living Waters – Semitic Hermeneutics', description = 'Comparative hermeneutics across Semitic traditions' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}favicon.svg`} />
</head>
<body>
  <div class="water-bg"></div>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
