---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const enArticles = await getCollection('en');
const frArticles = await getCollection('fr');

const categories = [
  {
    id: 'hermeneutics',
    titleEn: 'Hermeneutics',
    titleFr: 'Herméneutique',
  },
  {
    id: 'philosophy',
    titleEn: 'Philosophy & History',
    titleFr: 'Philosophie & Histoire',
  },
  {
    id: 'cultural',
    titleEn: 'Cultural Analysis',
    titleFr: 'Analyse culturelle',
  },
];

function getArticlesForCategory(cat: string) {
  return enArticles
    .filter(a => a.data.category === cat)
    .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
}

function getFrArticle(pair: string) {
  return frArticles.find(a => a.data.pair === pair);
}

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<BaseLayout>
  <section class="hero container">
    <h1 class="hero-title">Midrash</h1>
    <p class="hero-desc">
      <span data-lang="en" class="active">
        Comparative readings across Jewish, Christian, and Islamic traditions.
        Myth as mechanism, text as structure, hermeneutics as method.
      </span>
      <span data-lang="fr">
        Lectures comparées à travers les traditions juive, chrétienne et islamique.
        Le mythe comme mécanisme, le texte comme structure, l'herméneutique comme méthode.
      </span>
    </p>
  </section>

  <section class="articles container">
    {categories.map(cat => {
      const articles = getArticlesForCategory(cat.id);
      if (articles.length === 0) return null;
      return (
        <div class="category-section" id={cat.id}>
          <h2 class="category-title">
            <span data-lang="en" class="active">{cat.titleEn}</span>
            <span data-lang="fr">{cat.titleFr}</span>
          </h2>
          <ul class="article-list">
            {articles.map(article => {
              const fr = getFrArticle(article.data.pair);
              return (
                <li>
                  <a href={`${base}articles/${article.data.pair}/`} class="article-link">
                    <span class="article-title">
                      <span data-lang="en" class="active">{article.data.title}</span>
                      <span data-lang="fr">{fr?.data.title || article.data.title}</span>
                    </span>
                    <span class="article-desc">
                      <span data-lang="en" class="active">{article.data.description}</span>
                      <span data-lang="fr">{fr?.data.description || ''}</span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: var(--space-md);
    letter-spacing: -0.03em;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 36rem;
    margin: 0;
  }

  .articles {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  .category-section {
    margin-bottom: var(--space-xl);
  }

  .category-title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-top: 0;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border-light);
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-list li {
    border-bottom: 1px solid var(--border-light);
  }

  .article-list li:last-child {
    border-bottom: none;
  }

  .article-link {
    display: block;
    padding: var(--space-md) 0;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .article-link:hover {
    opacity: 0.7;
  }

  .article-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .article-desc {
    display: block;
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }

    .hero {
      padding-top: var(--space-xl);
    }
  }
</style>
