---
interface Props {
  slug: string;
  titleEn: string;
  titleFr: string;
  descEn: string;
  descFr: string;
}

const { slug, titleEn, titleFr, descEn, descFr } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<a href={`${base}articles/${slug}/`} class="article-card card ripple">
  <h3 class="article-title">
    <span data-lang="en" class="active">{titleEn}</span>
    <span data-lang="fr">{titleFr}</span>
  </h3>
  <p class="article-desc">
    <span data-lang="en" class="active">{descEn}</span>
    <span data-lang="fr">{descFr}</span>
  </p>
  <span class="article-read">
    <span data-lang="en" class="active">Read more &rarr;</span>
    <span data-lang="fr">Lire la suite &rarr;</span>
  </span>
</a>

<style>
  .article-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: var(--space-lg);
  }

  .article-title {
    font-size: 1.2rem;
    color: var(--water-deep);
    margin: 0 0 var(--space-sm);
  }

  .article-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
    line-height: 1.5;
  }

  .article-read {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--water-main);
    transition: color 0.2s;
  }

  .article-card:hover .article-read {
    color: var(--water-light);
  }
</style>
